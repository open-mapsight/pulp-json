{
    "name": "mapsight/pulp-json",
    "description": "Handlers for JSON and JSONP decoding and encoding.",
    "type": "library",
    "keywords": [
        "mapsight",
        "pulp",
        "json",
        "jsonp",
        "parsing"
    ],
    "homepage": "https://github.com/open-mapsight/mapsight-pulp",
    "license": "proprietary",
    "authors": [
        {
            "name": "Paul Golmann",
            "email": "mail@pje-web.de",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/open-mapsight/mapsight-pulp/issues",
        "source": "https://github.com/open-mapsight/mapsight-pulp/tree/main/packages/pulp-json"
    },
    "require": {
        "php": "^8.2",
        "symfony/polyfill-php83": "^1.37",
        "symfony/polyfill-php84": "^1.37",
        "symfony/polyfill-php85": "^1.37",
        "ext-json": "*",
        "ext-mbstring": "*",
        "mapsight/pulp": "*"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test": "phpunit test/"
    },
    "autoload": {
        "classmap": [
            "PulpJSON.php"
        ],
        "psr-4": {
            "OpenMapsight\\pulpjson\\": "src"
        }
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    },
    "archive": {
        "exclude": [
            "*",
            ".*",
            "!/src/*",
            "!/PulpJSON.php"
        ]
    }
}
